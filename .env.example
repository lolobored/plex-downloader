# Copy this file to .env and fill in the values
# cp .env.example .env

# PostgreSQL password (any string)
POSTGRES_PASSWORD=changeme

# JWT signing secret — must be at least 32 characters
JWT_SECRET=change-this-secret-min-32-chars-long

# Paths on the HOST machine that Plex uses
# These are mounted read-only into the backend container.
# Set to empty local dirs if you just want to bring the stack up without real media.
MOVIES_PATH=./dev-data/movies
TVSHOWS_PATH=./dev-data/tvshows

# Writable directory where converted files land (Tdarr input)
CONVERSION_PATH=./dev-data/conversion
